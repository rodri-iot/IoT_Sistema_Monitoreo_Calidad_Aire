
# Puerto del backend
PORT=3000

# Zona horaria IANA para agregaciones Mongo ($dateTrunc) y criterio de "día calendario" del negocio (LATAM).
# No cambiar por región AWS (ej. us-east-1): el servidor puede estar en UTC; el huso es el del producto.
APP_TIMEZONE=America/Argentina/Buenos_Aires

# MongoDB local (usado en docker-compose)
MONGO_URI=mongodb://mongo:27017/smca

# MQTT broker con TLS
MQTT_HOST=mqtts://mosquitto:8883
MQTT_TOPIC=iot/aire/lectura
MQTT_TOPIC_LWT=iot/aire/status
CLIENT_ID=backend_smca

# Rutas de certificados TLS (dentro del contenedor)
CA_CERT=./certs/ca.crt
CLIENT_CERT=./certs/client.crt
CLIENT_KEY=./certs/client.key
